// Y CRM — Prisma schema
// To regenerate the client after changes: npx prisma generate
// To push schema to database: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  hashedPassword String?   // Nullable for migration
  role           String    @default("user") // "admin" | "user"
  color          String    // hex color for owner indicator (e.g. "#deff00")
  initial        String    // single letter for owner dot (e.g. "N")
  createdAt      DateTime  @default(now())

  ownedDeals Deal[]     @relation("DealOwner")
  activities Activity[]
  targets    Target[]
  accounts   Account[]
  sessions   Session[]

  @@map("users")
}

model Stage {
  id     String @id @default(cuid())
  name   String
  order  Int
  // null status = open pipeline stage. "won" / "lost" = terminal stages.
  status String?

  deals  Deal[]

  @@unique([order])
  @@map("stages")
}

// CRM: Company (Företagsregister)
model Company {
  id          String    @id @default(cuid())
  name        String    // Original case preserved
  nameNorm    String    // Normalized for duplicate detection (lowercase, trimmed)
  orgNr       String?   // Organization number
  industry    String?   // Bransch
  website     String?
  address     String?
  employees   Int?      // Number of employees
  notes       String?   @db.Text

  contacts    Contact[]
  deals       Deal[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([nameNorm])
  @@index([nameNorm])
  @@map("companies")
}

// CRM: Contact (Kontaktpersoner)
model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  fullName    String    // For search/display
  title       String?   // Job title (e.g. "Inköpschef")
  email       String?
  phone       String?
  linkedin    String?
  notes       String?   @db.Text

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  deals       Deal[]
  participants  Participant[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([email])
  @@map("contacts")
}

model Deal {
  id         String     @id @default(cuid())
  title      String

  // NEW: Normalized relations (optional during migration)
  companyId  String?
  company_rel Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  contactId  String?
  contact_rel Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // OLD: Kept as backup during migration (will be removed later)
  company    String?
  contact    String?
  email      String?
  phone      String?

  value      Int        @default(0) // value in SEK (no decimals)
  notes      String?
  status     String     @default("open") // open | won | lost

  stageId    String
  stage      Stage      @relation(fields: [stageId], references: [id])

  ownerId    String
  owner      User       @relation("DealOwner", fields: [ownerId], references: [id])

  // Optional metadata kept from Pipedrive import for reference
  source     String?    // e.g. "pipedrive-import"
  sourceId   String?    // original Pipedrive deal ID

  wonAt      DateTime?  // when the deal was marked won
  lostAt     DateTime?  // when the deal was marked lost
  expectedCloseDate DateTime? // for forecasting

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  activities Activity[]

  @@index([stageId])
  @@index([ownerId])
  @@index([wonAt])
  @@index([companyId])
  @@index([contactId])
  @@index([projectId])
  @@map("deals")
}

model Activity {
  id          String   @id @default(cuid())
  type        String   // note | call | email | meeting
  content     String   @db.Text
  occurredAt  DateTime @default(now())

  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@map("activities")
}

// Sales targets. userId=null means a company-wide target.
// month=null means a yearly target. month=1-12 means a monthly target.
model Target {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  year      Int
  month     Int?     // 1-12, or null for yearly target
  amount    Int      // SEK
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([year])
  @@map("targets")
}

// NextAuth.js tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                  String   @id @default(cuid())
  name                String
  startDate           DateTime
  format              String?  @db.Text
  maxParticipants     Int
  pricePerParticipant Int
  status              String   @default("planned")
  notes               String?  @db.Text

  deals               Deal[]
  participants        Participant[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([startDate])
  @@map("projects")
}

model Participant {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status    String   @default("confirmed")
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, contactId])
  @@index([projectId])
  @@index([contactId])
  @@index([status])
  @@map("participants")
}
